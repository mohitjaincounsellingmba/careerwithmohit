# ==========================================
# CareerWithMohit - Social Media Automation
# ==========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git!

# --- Your Website ---
BASE_URL=https://careerwithmohit.com

# --- Instagram Business (via Meta Graph API) ---
# Get from: https://developers.facebook.com → Your App → Instagram → Credentials
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Facebook Page (via Meta Graph API) ---
# Get from: https://developers.facebook.com → Your App → Page Token
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# --- LinkedIn (via LinkedIn Developer API) ---
# Get from: https://www.linkedin.com/developers/apps → Your App
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX
